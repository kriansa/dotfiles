#!/usr/bin/env bash

# This is just a small help on top of `ansible-playbook` so I don't have to
# remember its interface
#
# Usage: bin/setup <[user@]host> <machine-type> [--debug]
#
# When using the --debug flag, it will only run the tasks that have been tagged
# with a 'only' tag. i.e.:
#   ---
#   name: do something
#   tags: [only]
#   command: echo 'something'

if [ "$#" -lt 2 ]; then
  echo "Usage: $0 <[user@]ip> <machine-type> [--debug]"
  exit 1
fi

# Get the arguments
host=$1
machine_type=$2
debug=$3

# Disable cowsay
export ANSIBLE_NOCOWS=1

# On localhost, we need to use a local connection
if test "${host}" = "localhost"; then
  # FIDO2/U2F hardware token authentication workaround for Ansible.
  # When using FIDO2-protected sudo, Ansible hangs waiting for interactive
  # token prompt. The workaround is to provide a dummy password via
  # ansible_become_pass, which satisfies Ansible's password check while
  # allowing sudo to proceed to FIDO2 interactive authentication.
  #
  # See: https://github.com/ansible/ansible/issues/86102
  #
  # Without this dummy password, Ansible fails immediately with:
  #   "sudo: a password is required"
  #
  # With the dummy password, Ansible passes it to sudo, which then
  # proceeds to FIDO2 authentication (waiting for token touch).
  extra_params=("--connection=local" "-e" "ansible_become_pass=dummy")
else
  extra_params=("--ssh-extra-args" "-o ForwardAgent=yes")
fi

test "${debug}" = "--debug" && extra_params+=("--tags=only")

# Run the playbook
cd ansible && ansible-playbook --inventory="${host}," "${extra_params[@]}" "${machine_type}.yml"
