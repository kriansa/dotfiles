#!/usr/bin/env bash
#
# term-probe — print a battery of terminal features so you can eyeball what
# your terminal actually supports: text styles, extended underlines, 16/256/
# 24-bit color, OSC 8 hyperlinks, and Unicode/glyph rendering.
#
# Usage: term-probe

set -u

e=$'\033'           # ESC
off="${e}[0m"       # reset all attributes
sample='The quick brown fox jumps'

section() { printf '\n%s[1;4m %s %s\n' "$e" "$1" "$off"; }

# attr CODE NAME — render NAME's sample with SGR parameter CODE, then echo CODE
attr() {
  printf '  %-22s %s[%sm%s%s  %s[90m(%s)%s\n' \
    "$2" "$e" "$1" "$sample" "$off" "$e" "$1" "$off"
}

# hue2rgb HUE(0-359) -> sets globals R G B (full-saturation, full-value)
hue2rgb() {
  local h=$1 rem region
  region=$(( h / 60 ))
  rem=$(( (h % 60) * 255 / 60 ))
  case $region in
    0) R=255;            G=$rem;          B=0 ;;
    1) R=$((255 - rem)); G=255;           B=0 ;;
    2) R=0;              G=255;           B=$rem ;;
    3) R=0;              G=$((255 - rem)); B=255 ;;
    4) R=$rem;           G=0;             B=255 ;;
    *) R=255;            G=0;             B=$((255 - rem)) ;;
  esac
}

# ---------------------------------------------------------------------------

section "Terminal identity"
printf '  TERM=%s   COLORTERM=%s   TERM_PROGRAM=%s\n' \
  "${TERM:-?}" "${COLORTERM:-?}" "${TERM_PROGRAM:-?}"
printf '  tput colors: %s   size (rows cols): %s\n' \
  "$(tput colors 2>/dev/null || echo '?')" "$(stty size 2>/dev/null || echo '?')"

section "Text attributes — common"
attr 1  bold
attr 2  'dim / faint'
attr 3  italic
attr 4  underline
attr 5  blink
attr 7  'reverse / inverse'
attr 8  'conceal (hidden)'
attr 9  strikethrough
attr 21 'double underline'
attr 53 overline

section "Text attributes — rare / poorly supported"
attr 6  'rapid blink'
attr 51 framed
attr 52 encircled
attr 73 superscript
attr 74 subscript

section "Extended underline styles (colon SGR)"
attr 4:1 'straight'
attr 4:2 'double'
attr 4:3 'curly / undercurl'
attr 4:4 'dotted'
attr 4:5 'dashed'
printf '  %-22s %s[4:3m%s[58:2::255:90:90m%s%s  %s[90m(4:3 + 58:2::r:g:b)%s\n' \
  'colored underline' "$e" "$e" "$sample" "$off" "$e" "$off"

section "Attribute combinations"
attr '1;3'     'bold + italic'
attr '1;4;38;5;39' 'bold + underline + color'
attr '3;9'     'italic + strikethrough'
attr '1;53'    'bold + overline'
attr '7;1'     'reverse + bold'

section "16 colors — foreground"
for c in 30 31 32 33 34 35 36 37 90 91 92 93 94 95 96 97; do
  printf '%s[%sm %3d %s' "$e" "$c" "$c" "$off"
done
printf '\n'

section "16 colors — background"
for c in 40 41 42 43 44 45 46 47 100 101 102 103 104 105 106 107; do
  printf '%s[%s;30m %3d %s' "$e" "$c" "$c" "$off"
done
printf '\n'

section "256 colors"
for i in $(seq 0 15); do
  printf '%s[48;5;%dm %3d %s' "$e" "$i" "$i" "$off"
  (( (i + 1) % 8 == 0 )) && printf '\n'
done
for i in $(seq 16 231); do
  printf '%s[48;5;%dm  %s' "$e" "$i" "$off"
  (( (i - 15) % 36 == 0 )) && printf '\n'
done
for i in $(seq 232 255); do
  printf '%s[48;5;%dm  %s' "$e" "$i" "$off"
done
printf '\n'

section "24-bit truecolor"
for h in $(seq 0 6 359); do
  hue2rgb "$h"
  printf '%s[48;2;%d;%d;%dm %s' "$e" "$R" "$G" "$B" "$off"
done
printf '\n'
for i in $(seq 0 4 255); do
  printf '%s[48;2;%d;%d;%dm %s' "$e" "$i" "$i" "$i" "$off"
done
printf '\n'

section "Hyperlinks (OSC 8)"
osc8="${e}]8;;"
st="${e}\\"
printf '  %s%s%sthis text should be a clickable link%s%s%s  %s[90m(-> example.com)%s\n' \
  "$osc8" "https://example.com" "$st" "$osc8" "$st" "$off" "$e" "$off"

section "Unicode & glyph rendering"
printf '  %-18s %s\n' 'accented latin'  'café  naïve  Þórr  Ærøskøbing  ¿señor?'
printf '  %-18s %s\n' 'cjk (wide)'      '日本語  中文  한국어  ｆｕｌｌｗｉｄｔｈ'
printf '  %-18s %s\n' 'emoji'           '😀 🚀 🎉 ✅ 🔥  family: 👨‍👩‍👧‍👦  flag: 🇧🇷'
printf '  %-18s %s\n' 'combining'       'a+◌̅ = a̅   e+◌́ = é   o+◌̈ = ö'
printf '  %-18s %s\n' 'box drawing'     '┌─┬─┐ ╔═╦═╗ ╭─┬─╮ │ ├─┼─┤ └─┴─┘'
printf '  %-18s %s\n' 'blocks / shades' '░▒▓█  ▁▂▃▄▅▆▇█  ◐◑◒◓  ▔▏▎▍▌▋▊▉'
printf '  %-18s %s\n' 'braille'         '⠁⠉⠙⠹⠽⣿⣷⣯⣟⡿⢿⣻⣽⣾'
printf '  %-18s %s\n' 'powerline'       '         (needs a patched font)'
printf '  %-18s %s\n' 'nerd font'       '                 (needs Nerd Font)'

printf '  %-18s |%s|\n' 'wide align A' 'AAAA'
printf '  %-18s |%s|\n' 'wide align B' '日本語'

section "Kitty graphics protocol (render test)"
printf '  Colored bars below = kitty graphics works.  Escape soup = not supported.\n'
# Hand-rolled kitty image (only dep: base64): 6 stacked color bars, 120x72 RGB.
kw=120 kh=72
# Raw RGB pixels piped straight to base64 — binary never enters a shell var.
b64=$(
  {
    printf '\xff\x00\x00%.0s' {1..1440}            # red    (120x12)
    printf '\x00\xff\x00%.0s' {1..1440}            # green
    printf '\x00\x00\xff%.0s' {1..1440}            # blue
    printf '\x00\xff\xff%.0s' {1..1440}            # cyan
    printf '\xff\x00\xff%.0s' {1..1440}            # magenta
    printf '\xff\xff\x00%.0s' {1..1440}            # yellow
  } | base64 | tr -d '\n'
)
# Emit as APC chunks (<=4096 b64 bytes each); first chunk carries the metadata.
len=${#b64} off=0 first=1
while (( off < len )); do
  chunk=${b64:off:4096}
  off=$(( off + 4096 ))
  m=1; (( off >= len )) && m=0
  if (( first )); then
    printf '%s_Ga=T,f=24,s=%d,v=%d,q=2,m=%d;%s%s\\' "$e" "$kw" "$kh" "$m" "$chunk" "$e"
    first=0
  else
    printf '%s_Gm=%d;%s%s\\' "$e" "$m" "$chunk" "$e"
  fi
done
printf '\n'

printf '\n%s[2mNote: sixel and cursor styles need a dedicated probe.%s\n' "$e" "$off"
printf '%s[2mKitty graphics above is swallowed by tmux unless allow-passthrough is on.%s\n' "$e" "$off"
