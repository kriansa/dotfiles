#!/usr/bin/env bash
#
# tmux-nest - open a tmux session nested in a new window of the current tmux.
#
# The nested session runs on its own tmux server (`tmux -L <socket>`) so its
# bindings and sessions are isolated from the outer. The outer's tmux.conf
# recognizes the nest's pane via the @nest-host pane option (set below) and
# routes most root-table keys (C-\, C-l, S-PageUp, …) to the inner tmux. See
# the "tmux-nest integration" block in tmux.conf for the full picture.
#
# The nest always opens in a brand-new outer window whose command IS the attach,
# so it never takes over the current pane (which might be a split) and its
# @nest-host dies with the window when the nest ends - no teardown needed.

set -euo pipefail

usage() {
  cat <<'EOF'
tmux-nest - open a nested tmux session in a new window.

Usage: tmux-nest [--path DIR] [session-name]
       tmux-nest --ssh HOST [session-name]
       tmux-nest --help

Options:
  --path DIR     Starting directory for the inner session. If omitted, the
                 inner inherits the current pane's directory.
  --ssh HOST     SSH into HOST and attach to (or create) a tmux session there
                 instead of spawning a local inner server. Incompatible with
                 --path.
  -h, --help     Show this help and exit.

Argument:
  session-name   Name for the nested session (and for the remote tmux session
                 when using --ssh). If omitted, defaults to HOST with --ssh;
                 otherwise it is required.
EOF
}

# Orchestrate one nested-session launch: parse args, refuse over SSH, resolve
# and sanitize the name, then open the nest in a new window.
main() {
  session_path=""
  session_name=""
  ssh_host=""

  parse-args "$@"
  refuse-if-ssh
  validate-session-name
  sanitize-names
  open-nest-window
}

# Parse options and the optional positional name into globals. Exits 2 on any
# argument error (printing usage on an unknown option) and 0 after --help.
parse-args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path)
        [[ $# -lt 2 ]] && { echo "tmux-nest: --path requires an argument" >&2; exit 2; }
        session_path="$2"
        shift 2
        ;;
      --path=*)
        session_path="${1#--path=}"
        [[ -z "$session_path" ]] && { echo "tmux-nest: --path requires an argument" >&2; exit 2; }
        shift
        ;;
      --ssh)
        [[ $# -lt 2 ]] && { echo "tmux-nest: --ssh requires a host argument" >&2; exit 2; }
        ssh_host="$2"
        shift 2
        ;;
      --ssh=*)
        ssh_host="${1#--ssh=}"
        [[ -z "$ssh_host" ]] && { echo "tmux-nest: --ssh requires a host argument" >&2; exit 2; }
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "tmux-nest: unknown option '$1'" >&2
        usage >&2
        exit 2
        ;;
      *)
        if [[ -z "$session_name" ]]; then
          session_name="$1"
          shift
        else
          echo "tmux-nest: unexpected argument '$1'" >&2
          exit 2
        fi
        ;;
    esac
  done

  # --ssh attaches to a remote's default server; --path sets a local inner's
  # start dir. There's no local inner to point at over SSH, so they conflict.
  if [[ -n "$ssh_host" && -n "$session_path" ]]; then
    echo "tmux-nest: --ssh and --path are incompatible" >&2
    exit 2
  fi
}

# Nesting only makes sense on the machine hosting the OUTER tmux. Over SSH we're
# already a hop deep (local outer -> SSH nest -> here), so nesting again would
# stack a third tmux. tmux's default update-environment carries SSH_CONNECTION
# into every window the keybinding opens, so its presence reliably means we're
# being viewed over SSH.
refuse-if-ssh() {
  if [[ -n "${SSH_CONNECTION:-}" ]]; then
    echo "tmux-nest: refusing to nest inside an SSH session" >&2
    exit 1
  fi
}

# If a session name isn't given and we can't use a fallback, error out.
validate-session-name() {
  if [[ -n "$session_name" ]]; then
    return 0
  elif [[ -n "$ssh_host" ]]; then
    session_name="$ssh_host"
  else
    echo "You need to specify a session name!" >&2
    exit 1
  fi
}

# Two levels of sanitization:
#   1. socket name (-L): becomes a file at /tmp/tmux-<uid>/<name>, so must
#      be filesystem-safe - strip everything outside [A-Za-z0-9_-].
#   2. session name (-s/-t): tmux uses ':' and '.' as target separators
#      (session:window.pane), so it rejects names containing them; spaces,
#      other punctuation, and emoji are fine.
# Only the two structural chars get replaced in the user-visible name.
sanitize-names() {
  safe_name=$(printf '%s' "$session_name" | sed 's/[^A-Za-z0-9_-]/_/g')
  if [[ -z "$safe_name" ]]; then
    echo "tmux-nest: session name '$session_name' has no usable characters" >&2
    exit 1
  fi
  session_name=${session_name//:/_}
  session_name=${session_name//./_}
}

# Open the nest in a brand-new outer window whose command IS the attach, then
# mark that window's pane as the nest host. We never attach in the current pane,
# so the nest owns a whole window and its @nest-host dies with the window on exit.
#
# Every outer command clears $TMUX so it targets the default (outer) server.
# That makes this work unchanged when run from *inside* a nest: the new nest
# opens as a sibling one level up on the outer, never stacked.
open-nest-window() {
  # Default the inner's start dir to the focused pane's cwd. Query tmux rather
  # than trusting $PWD: invoked from the key binding via run-shell, our cwd is
  # the server's, not the pane's.
  if [[ -z "$session_path" && -z "$ssh_host" ]]; then
    session_path=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null || true)
  fi

  local window_cmd
  if [[ -n "$ssh_host" ]]; then
    # Two quoting layers: %q on the names for the remote shell, then the whole
    # remote command is one argument to ssh inside the new-window command that
    # the local `sh -c` parses. bell-action any: focus events don't reach the
    # inner reliably over ssh, so a bell in its current window wouldn't ring.
    local remote
    remote=$(printf 'tmux new-session -A -d -s %q 2>/dev/null; tmux set-option -g bell-action any; exec tmux attach-session -t %q' \
      "$session_name" "$session_name")
    window_cmd=$(printf 'exec ssh %q -t %q' "$ssh_host" "$remote")
  else
    create-local-inner
    # %q so the socket/session names survive the new-window `sh -c` re-parse.
    window_cmd=$(printf 'exec tmux -L %q attach-session -t %q' "$safe_name" "$session_name")
  fi

  # The window's command is the attach, so the window lives exactly as long as
  # the nest. @active-is-nested is set explicitly: setting a pane option doesn't
  # fire tmux.conf's mirror hooks that normally maintain it.
  local pane
  pane=$(TMUX="" tmux new-window -P -F '#{pane_id}' "$window_cmd")
  TMUX="" tmux set-option -p -t "$pane" @nest-host "$session_name"
  TMUX="" tmux set-option @active-is-nested "$session_name"
  TMUX="" tmux rename-window -t "$pane" "$session_name"
}

# Create the inner session on its OWN tmux server (a dedicated `-L` socket),
# detached, and mark the server with @nest-inner so its tmux.conf focus hooks
# switch bell-action dynamically (other while visible, any while hidden) - so the
# outer rings the nested tab only when it isn't already showing it. `new-session
# -A` reattaches if the named session already exists, else creates it.
create-local-inner() {
  local new_session_args=(new-session -A -d -s "$session_name")
  [[ -n "$session_path" ]] && new_session_args+=(-c "$session_path")

  # Seed the inner server's environment from the OUTER (default) server's global
  # env, not this process's: a tmux server freezes the env of whatever first
  # spawns it and hands that to every pane, so reading it back from the outer
  # gives the same baseline minus the launching pane's per-process cruft
  # (CLAUDE_CODE_*, editor vars, …) and stops nesting from compounding it. Global
  # scope, because session scope drops PATH/HOME. Skip removal markers (-NAME)
  # and TMUX/TMUX_PANE so the inner starts unaware it's nested. Empty result ->
  # fall back rather than spawn with no environment.
  local nest_env=()
  local line
  while IFS= read -r line; do
    case "$line" in
      -*|TMUX=*|TMUX_PANE=*) ;;
      *=*) nest_env+=("$line") ;;
    esac
  done < <(TMUX="" tmux show-environment -g 2>/dev/null)

  if [[ ${#nest_env[@]} -gt 0 ]]; then
    env -i "${nest_env[@]}" tmux -L "$safe_name" "${new_session_args[@]}" 2>/dev/null || true
  else
    TMUX="" tmux -L "$safe_name" "${new_session_args[@]}" 2>/dev/null || true
  fi

  TMUX="" tmux -L "$safe_name" set-option -s @nest-inner 1
}

main "$@"
