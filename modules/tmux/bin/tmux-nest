#!/usr/bin/env bash
#
# tmux-nest - open a tmux session nested inside the current tmux pane.
#
# The nested session runs on its own tmux server (`tmux -L <socket>`) so its
# bindings and sessions are isolated from the outer. The outer's tmux.conf
# recognizes nested panes via the @nest-host pane option (set below) and
# routes most root-table keys (C-\, C-l, S-PageUp, …) to the inner tmux. See
# the "tmux-nest integration" block in tmux.conf for the full picture.

set -euo pipefail

usage() {
  cat <<'EOF'
tmux-nest - open a nested tmux session in the current pane.

Usage: tmux-nest [--path DIR] [session-name]
       tmux-nest --ssh HOST [session-name]
       tmux-nest --help

Options:
  --path DIR     Starting directory for the inner session. If omitted, the
                 inner inherits the pane's current directory.
  --ssh HOST     SSH into HOST and attach to (or create) a tmux session there
                 instead of spawning a local inner server. Incompatible with
                 --path.
  -h, --help     Show this help and exit.

Argument:
  session-name   Name for the nested session (and for the remote tmux session
                 when using --ssh). If omitted, defaults to HOST with --ssh;
                 otherwise it is required.
EOF
}

# Orchestrate one nested-session launch: parse args, refuse over SSH, hand off
# if we're already nested, resolve and sanitize the name, prime the outer pane,
# then attach.
main() {
  # Snapshot argv before parse-args consumes it; a nested invocation replays it
  # verbatim on the parent tmux (see maybe-handoff-if-nested).
  original_args=("$@")

  # Arguments we'll use across the script
  session_path=""
  session_name=""
  ssh_host=""

  parse-args "$@"
  refuse-if-ssh
  maybe-handoff-if-nested
  validate-session-name
  sanitize-names
  setup-outer-pane
  launch-inner
}

# Parse options and the optional positional name into globals. Exits 2 on any
# argument error (printing usage on an unknown option) and 0 after --help.
parse-args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path)
        [[ $# -lt 2 ]] && { echo "tmux-nest: --path requires an argument" >&2; exit 2; }
        session_path="$2"
        shift 2
        ;;
      --path=*)
        session_path="${1#--path=}"
        [[ -z "$session_path" ]] && { echo "tmux-nest: --path requires an argument" >&2; exit 2; }
        shift
        ;;
      --ssh)
        [[ $# -lt 2 ]] && { echo "tmux-nest: --ssh requires a host argument" >&2; exit 2; }
        ssh_host="$2"
        shift 2
        ;;
      --ssh=*)
        ssh_host="${1#--ssh=}"
        [[ -z "$ssh_host" ]] && { echo "tmux-nest: --ssh requires a host argument" >&2; exit 2; }
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "tmux-nest: unknown option '$1'" >&2
        usage >&2
        exit 2
        ;;
      *)
        if [[ -z "$session_name" ]]; then
          session_name="$1"
          shift
        else
          echo "tmux-nest: unexpected argument '$1'" >&2
          exit 2
        fi
        ;;
    esac
  done

  # --ssh attaches to a remote's default server; --path sets a local inner's
  # start dir. There's no local inner to point at over SSH, so they conflict.
  if [[ -n "$ssh_host" && -n "$session_path" ]]; then
    echo "tmux-nest: --ssh and --path are incompatible" >&2
    exit 2
  fi
}

# Nesting only makes sense on the machine hosting the OUTER tmux. Over SSH we're
# already a hop deep (local outer -> SSH nest -> here), so nesting again would
# stack a third tmux. tmux's default update-environment carries SSH_CONNECTION
# into every window the keybinding opens, so its presence reliably means we're
# being viewed over SSH.
refuse-if-ssh() {
  if [[ -n "${SSH_CONNECTION:-}" ]]; then
    echo "tmux-nest: refusing to nest inside an SSH session" >&2
    exit 1
  fi
}

# A nested (inner) server is marked with the @nest-inner server option on its
# socket; when we're attached to one, $TMUX points at it so a bare tmux talks
# to the inner. Nesting at this point would stack a THIRD tmux on a third socket.
# Instead, replay this invocation on the OUTER tmux so the session opens as a
# sibling nest one level up, not a third level down. This setup only ever runs
# one tmux server - the default - as the outer, so clearing $TMUX (it points at
# the inner's -L socket here) routes a bare tmux to the default server, i.e. the
# outer. (--help already exited during parsing, so it never reaches here.)
maybe-handoff-if-nested() {
  if [[ -n "${TMUX:-}" ]] &&
     [[ "$(tmux show-options -sv @nest-inner 2>/dev/null || true)" == "1" ]]; then
    # Rebuild the command, single-quoting each argument so spaces survive the
    # outer shell's word-splitting. Replaying argv verbatim preserves tmux-nest's
    # own semantics: no positional -> the outer errors out; an empty '' -> the
    # outer cancels - exactly as a direct run would.
    local forward="tmux-nest"
    if [[ ${#original_args[@]} -gt 0 ]]; then
      local arg
      for arg in "${original_args[@]}"; do
        forward="$forward '$arg'"
      done
    fi

    TMUX="" tmux new-window "$forward"
    exit 0
  fi
}

# If a session name isn't given and we can't use a fallback, error out
validate-session-name() {
  if [[ -n "$session_name" ]]; then
    return 0
  elif [[ -n "$ssh_host" ]]; then
    session_name="$ssh_host"
  else
    echo "You need to specify a session name!" >&2
    exit 1
  fi
}

# Two levels of sanitization:
#   1. socket name (-L): becomes a file at /tmp/tmux-<uid>/<name>, so must
#      be filesystem-safe - strip everything outside [A-Za-z0-9_-].
#   2. session name (-s/-t): tmux uses ':' and '.' as target separators
#      (session:window.pane), so it rejects names containing them; spaces,
#      other punctuation, and emoji are fine.
# Only the two structural chars get replaced in the user-visible name.
sanitize-names() {
  safe_name=$(printf '%s' "$session_name" | sed 's/[^A-Za-z0-9_-]/_/g')
  if [[ -z "$safe_name" ]]; then
    echo "tmux-nest: session name '$session_name' has no usable characters" >&2
    exit 1
  fi
  session_name=${session_name//:/_}
  session_name=${session_name//./_}
}

# Mark this outer pane as a nest host (drives tmux.conf's key routing and tab
# styling) and rename the outer window so it's identifiable in the tab list.
# Register the EXIT trap here, paired with the state cleanup tears down.
setup-outer-pane() {
  tmux set-option -p @nest-host "$session_name"
  tmux set-option @active-is-nested "$session_name"
  tmux rename-window "$session_name"

  trap cleanup EXIT
}

# Whatever exit path we take (detach, kill-session, error, signal), drop the
# nest-host markers so tmux.conf's key routing and tab styling revert.
cleanup() {
  tmux set-option -p -u @nest-host 2>/dev/null || true
  tmux set-option -u @active-is-nested 2>/dev/null || true
}

# Ensure the inner session exists, then attach in the foreground - which blocks
# until detach or session kill, after which `cleanup` runs via the EXIT trap.
# The two branches differ in where the inner runs and how bells are handled.
launch-inner() {
  if [[ -n "$ssh_host" ]]; then
    launch-inner-ssh
  else
    launch-inner-local
  fi
}

# SSH: the bell focus mechanism needs focus events to reach the inner reliably,
# which they don't through SSH - so a bell in the inner's *current* window never
# propagates while bell-action is `other`. So we just force bell-action `any`.
# SSH nests attach to the remote's DEFAULT tmux server (no `-L`); by request we
# set `bell-action any` there and leave it in place (no reset). Nothing sets
# @nest-inner on the default server (local nesting only ever sets it on its own
# `-L` socket), so the focus hooks stay no-ops and `any` sticks. The socket is
# implicit; only the session target needs quoting for the remote shell.
launch-inner-ssh() {
  local session_q
  session_q=$(printf '%q' "$session_name")
  ssh "$ssh_host" -t "tmux new-session -A -d -s $session_q 2>/dev/null; tmux set-option -g bell-action any; tmux attach-session -t $session_q"
}

# Local: run the inner on its OWN tmux server (a dedicated `-L` socket), isolated
# from any default server, and mark it with @nest-inner so its tmux.conf focus
# hooks switch bell-action dynamically (other while visible, any while hidden) -
# so the outer rings the nested tab only when it isn't already showing it.
# `new-session -A` attaches to the inner if it already exists, else creates it.
launch-inner-local() {
  local new_session_args=(new-session -A -d -s "$session_name")
  [[ -n "$session_path" ]] && new_session_args+=(-c "$session_path")

  # Start the inner server from a clean baseline: the OUTER tmux server's global
  # environment (`tmux show-environment -g`), not the launching pane's shell env.
  # A tmux server snapshots the environment of whatever command first spawns it
  # (the new-session below) and hands that frozen copy to every pane it ever
  # creates. The launching pane has piled its own process vars on top of the
  # server baseline (CLAUDE_CODE_*, OLDPWD, editor/tool vars, …); reading the env
  # back from the outer server gives the same baseline the outer itself runs with
  # - minus that per-pane cruft - and stops nesting-within-nesting from
  # compounding it. We read GLOBAL scope because the session scope omits PATH,
  # HOME and other essentials. Removal markers (`-NAME`) and TMUX/TMUX_PANE are
  # skipped so the inner starts unaware it's nested. If show-environment yields
  # nothing (not in a session, or it errored), fall back to the old behavior
  # rather than spawning a server with an empty environment.
  local nest_env=()
  local line
  while IFS= read -r line; do
    case "$line" in
      -*|TMUX=*|TMUX_PANE=*) ;; # skip the env removals (those prefixed with +) and nesting markers
      *=*) nest_env+=("$line") ;;
    esac
  done < <(tmux show-environment -g 2>/dev/null)

  if [[ ${#nest_env[@]} -gt 0 ]]; then
    env -i "${nest_env[@]}" tmux -L "$safe_name" "${new_session_args[@]}" 2>/dev/null || true
  else
    TMUX="" tmux -L "$safe_name" "${new_session_args[@]}" 2>/dev/null || true
  fi

  TMUX="" tmux -L "$safe_name" set-option -s @nest-inner 1
  TMUX="" tmux -L "$safe_name" attach-session -t "$session_name"
}

main "$@"
