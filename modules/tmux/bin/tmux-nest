#!/usr/bin/env bash
#
# tmux-nest — open a tmux session nested inside the current tmux pane.
#
# The nested session runs on its own tmux server (`tmux -L <socket>`) so its
# bindings and sessions are isolated from the outer. The outer's tmux.conf
# recognizes nested panes via the @nest-host pane option (set below) and
# routes most root-table keys (C-\, C-l, S-PageUp, …) to the inner tmux. See
# the "tmux-nest integration" block in tmux.conf for the full picture.

set -euo pipefail

usage() {
  cat <<'EOF'
tmux-nest — open a nested tmux session in the current pane.

Usage: tmux-nest [--path DIR] [--new-window] [session-name]
       tmux-nest --ssh HOST [--new-window] [session-name]
       tmux-nest --help

Options:
  --path DIR     Starting directory for the inner session. If omitted, the
                 inner inherits the pane's current directory.
  --ssh HOST     SSH into HOST and attach to (or create) a tmux session there
                 instead of spawning a local inner server. Incompatible with
                 --path.
  --new-window   Prompt for a name (if not provided), then open a new outer
                 window running tmux-nest there. Used by the Super+Shift+T
                 popup binding; safe to call from a shell too.
  -h, --help     Show this help and exit.

Argument:
  session-name   Name for the nested session (and for the remote tmux session
                 when using --ssh). If omitted, defaults to HOST with --ssh,
                 otherwise prompts interactively.
EOF
}

# --- Argument parsing -------------------------------------------------------

session_path=""
new_window=0
session_name=""
ssh_host=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --path)
      [[ $# -lt 2 ]] && { echo "tmux-nest: --path requires an argument" >&2; exit 2; }
      session_path="$2"
      shift 2
      ;;
    --path=*)
      session_path="${1#--path=}"
      shift
      ;;
    --ssh)
      [[ $# -lt 2 ]] && { echo "tmux-nest: --ssh requires a host argument" >&2; exit 2; }
      ssh_host="$2"
      shift 2
      ;;
    --ssh=*)
      ssh_host="${1#--ssh=}"
      shift
      ;;
    --new-window)
      new_window=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "tmux-nest: unknown option '$1'" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$session_name" ]]; then
        session_name="$1"
        shift
      else
        echo "tmux-nest: unexpected argument '$1'" >&2
        exit 2
      fi
      ;;
  esac
done

if [[ -n "$ssh_host" && -n "$session_path" ]]; then
  echo "tmux-nest: --ssh and --path are incompatible" >&2
  exit 2
fi

# --- Name prompt ------------------------------------------------------------
# Prompt for a session name into the global `session_name`, returning non-zero
# if the user cancels. Uses bash's readline (`read -e`) for full line editing —
# Backspace, Ctrl-W (word), Ctrl-U (line), Ctrl-A/E, Alt-f/Alt-b word motion,
# and Ctrl-Left/Right (bound below) — none of which a plain `read` provides.
#
# readline has no built-in "Esc cancels", so we bind a bare Esc to a macro that
# jumps to end, kills the line, types a sentinel and accepts; the caller treats
# that sentinel as a cancel (used to dismiss the Super+Shift+T popup). A short
# keyseq-timeout lets readline tell a lone Esc from the start of an escape
# sequence (arrows, …). These binds are local to this short-lived process, so
# they don't touch the user's interactive shell. Falls back to plain `read`
# when stdin isn't a TTY (e.g. piped input).
#
# Ctrl-Left/Right emit a terminal-dependent sequence; the binds cover the two
# common encodings. If they don't move by word in some terminal, Alt-f/Alt-b
# always do.
prompt_session_name() {
  local prompt="Nested session name: " reply=""
  local sentinel="__tmux_nest_cancelled__"

  if [[ ! -t 0 ]]; then
    IFS= read -rp "$prompt" reply || return 1
    session_name="$reply"
    return 0
  fi

  bind 'set keyseq-timeout 50'             2>/dev/null  # snappy lone-Esc detection
  bind "\"\e\": \"\C-e\C-u${sentinel}\r\"" 2>/dev/null  # Esc -> sentinel + accept
  bind '"\e[1;5C": forward-word'           2>/dev/null  # Ctrl-Right
  bind '"\e[1;5D": backward-word'          2>/dev/null  # Ctrl-Left
  bind '"\e[5C": forward-word'             2>/dev/null  # Ctrl-Right (alt encoding)
  bind '"\e[5D": backward-word'            2>/dev/null  # Ctrl-Left  (alt encoding)

  IFS= read -erp "$prompt" reply || return 1
  [[ "$reply" == "$sentinel" ]] && return 1
  session_name="$reply"
  return 0
}

# --- --new-window mode ------------------------------------------------------
# When invoked from the Super+Shift+T popup (or any caller that wants the
# nested session to open in a fresh outer window), prompt for the name here
# — we have a TTY in the popup's shell — and then exec into a new outer
# window running tmux-nest with the captured name. The popup closes when
# this process exits; the new window picks up the real work.

if [[ $new_window -eq 1 ]]; then
  if [[ -z "$session_name" ]]; then
    prompt_session_name || exit 0
    [[ -z "$session_name" ]] && exit 0
  fi
  nest_args=(tmux-nest)
  [[ -n "$ssh_host" ]]    && nest_args+=(--ssh "$ssh_host")
  [[ -n "$session_path" ]] && nest_args+=(--path "$session_path")
  nest_args+=("$session_name")
  exec tmux new-window "${nest_args[@]}"
fi

# --- Interactive prompt fallback --------------------------------------------
# Bare invocation from a shell — ask for the name now.

if [[ -z "$session_name" ]]; then
  if [[ -n "$ssh_host" ]]; then
    session_name="$ssh_host"
  else
    prompt_session_name || { echo "Cancelled" >&2; exit 0; }
    if [[ -z "$session_name" ]]; then
      echo "Cancelled" >&2
      exit 0
    fi
  fi
fi

# --- Sanitize ---------------------------------------------------------------
# Two levels of sanitization:
#   1. socket name (-L): becomes a file at /tmp/tmux-<uid>/<name>, so must
#      be filesystem-safe — strip everything outside [A-Za-z0-9_-].
#   2. session name (-s/-t): tmux uses ':' and '.' as target separators
#      (session:window.pane), so it rejects names containing them; spaces,
#      other punctuation, and emoji are fine.
# Only the two structural chars get replaced in the user-visible name.

safe_name=$(printf '%s' "$session_name" | sed 's/[^A-Za-z0-9_-]/_/g')
if [[ -z "$safe_name" ]]; then
  echo "tmux-nest: session name '$session_name' has no usable characters" >&2
  exit 1
fi
session_name=${session_name//:/_}
session_name=${session_name//./_}

# --- Outer pane setup -------------------------------------------------------
# Mark this outer pane as a nest host (drives tmux.conf's key routing and
# tab-fade) and rename the outer window so it's identifiable in the tab list.
# Save the original window name so cleanup can restore it.

original_window_name=$(tmux display-message -p '#{window_name}')

tmux set-option -p @nest-host "$session_name"
tmux set-option @active-is-nested "$session_name"
tmux rename-window "$session_name"

# --- Cleanup ----------------------------------------------------------------
# Whatever exit path we take (detach, kill-session, error, signal), restore
# the outer pane's state and close the pane that hosted us.

cleanup() {
  tmux set-option -p -u @nest-host 2>/dev/null || true
  tmux set-option -u @active-is-nested 2>/dev/null || true
  tmux rename-window "$original_window_name" 2>/dev/null || true
  tmux set-window-option automatic-rename on 2>/dev/null || true
  tmux kill-pane 2>/dev/null || true
}
trap cleanup EXIT

# --- Launch inner -----------------------------------------------------------
# Both branches follow the same shape: ensure the inner session exists
# (detached; create fails silently if it already does), then attach in the
# foreground — which blocks until detach or session kill, after which
# `cleanup` runs via the EXIT trap. Both also run the inner on its OWN tmux
# server (a dedicated `-L` socket), isolated from any default server, so the
# options we set below never leak and need no cleanup. They differ only in how
# bells are handled.
#
# Local: mark the inner server with @nest-inner so its tmux.conf focus hooks
# switch bell-action dynamically (other while visible, any while hidden),
# letting the outer ring the nested tab only when it isn't already showing it.
#
# SSH: that focus mechanism relies on focus events reaching the inner reliably,
# which they don't through SSH — so a bell in the inner's *current* window
# never propagates while bell-action is stuck at `other`. Instead we force
# bell-action `any` so every inner bell propagates. Because the remote runs on
# a dedicated socket, that setting affects nothing else and never needs
# resetting; the fresh socket also has no @nest-inner, so the focus hooks are
# no-ops without any unsetting. safe_name is already shell-safe (sanitized to
# [A-Za-z0-9_-]); only the session target needs quoting for the remote shell.

if [[ -n "$ssh_host" ]]; then
  session_q=$(printf '%q' "$session_name")
  ssh "$ssh_host" -t "tmux -L $safe_name new-session -d -s $session_q 2>/dev/null; tmux -L $safe_name set-option -g bell-action any; tmux -L $safe_name attach-session -t $session_q"
else
  new_session_args=(new-session -d -s "$session_name")
  [[ -n "$session_path" ]] && new_session_args+=(-c "$session_path")

  TMUX="" tmux -L "$safe_name" "${new_session_args[@]}" 2>/dev/null || true
  TMUX="" tmux -L "$safe_name" set-option -s @nest-inner 1
  TMUX="" tmux -L "$safe_name" attach-session -t "$session_name"
fi
