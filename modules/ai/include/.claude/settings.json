{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "xhigh",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "preferredNotifChannel": "terminal_bell",
  "voiceEnabled": true,
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command"
  },
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "env": {
    "CLAUDE_CODE_SHELL": "/bin/zsh",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_INSTALLATION_CHECKS": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'export PATH=\"$HOME/.bin:$PATH\"' >> \"$CLAUDE_ENV_FILE\""
          }
        ]
      }
    ]
  }
}
